{
  "expo": {
    "name": "Nearby & Now",
    "slug": "nearbynow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/nearbynow-app-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nearbynow.app"
    },
    "android": {
      "package": "com.nearbynow.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/nearbynow-app-icon.png",
      "name": "Nearby & Now",
      "shortName": "Nearby & Now",
      "description": "Discover what's happening near you — local events, things to do, and recommendations all in one feed.",
      "backgroundColor": "#F5F0E6",
      "themeColor": "#F5F0E6"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Nearby & Now uses your location to show nearby events and recommendations."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/nearbynow-app-icon.png",
          "color": "#E0392A",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Nearby & Now"
        }
      ]
    ],
    "scheme": "nearbynow",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
